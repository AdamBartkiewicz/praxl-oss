# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
#
# NOTE: If you are using `docker compose up` (recommended), LEAVE THIS COMMENTED.
# docker-compose.yml sets DATABASE_URL automatically with the correct internal
# hostname (db, not localhost). Uncommenting this line and copying the example
# value can confuse manual debugging — the docker `environment:` block wins,
# but having a stale localhost URL in .env is a footgun.
#
# Uncomment ONLY for manual (non-Docker) installs, with your real credentials:
# DATABASE_URL=postgresql://praxl:praxl@localhost:5432/praxl

# JWT secret for session tokens — REQUIRED, app will refuse to start without it.
# Generate one and paste it here:
#   openssl rand -base64 32
AUTH_SECRET=change-me-to-a-random-string

# ─── Admin ───────────────────────────────────────────────────────────────────

# Comma-separated user IDs that have admin access.
# After first signup, get your ID from the database (see SETUP-WITH-AI.md
# step 6) and paste it here. Multiple admins: separate with commas.
# Read at runtime — change + `docker compose up -d --force-recreate app` is
# enough to apply, no rebuild needed.
ADMIN_USER_IDS=

# ─── App URL ─────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── AI (optional) ───────────────────────────────────────────────────────────

# Server-side Anthropic key for "AI included" mode
# If not set, users must provide their own key in Settings
# ANTHROPIC_SERVER_KEY=sk-ant-...

# AES-256 key for encrypting stored API keys (generate with: openssl rand -hex 32)
# ENCRYPTION_KEY=

# ─── Cron Jobs ───────────────────────────────────────────────────────────────

# Secret for authenticating cron job requests
# CRON_SECRET=

# ─── GitHub (optional) ───────────────────────────────────────────────────────

# GitHub PAT for higher API rate limits (marketplace indexing)
# GITHUB_TOKEN=
