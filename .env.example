# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://praxl:praxl@localhost:5432/praxl

# JWT secret for session tokens (generate with: openssl rand -base64 32)
AUTH_SECRET=change-me-to-a-random-string

# ─── Admin ───────────────────────────────────────────────────────────────────

# Comma-separated user IDs that have admin access
# After first signup, check the users table for your ID
ADMIN_USER_IDS=
NEXT_PUBLIC_ADMIN_USER_IDS=

# ─── App URL ─────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── AI (optional) ───────────────────────────────────────────────────────────

# Server-side Anthropic key for "AI included" mode
# If not set, users must provide their own key in Settings
# ANTHROPIC_SERVER_KEY=sk-ant-...

# AES-256 key for encrypting stored API keys (generate with: openssl rand -hex 32)
# ENCRYPTION_KEY=

# ─── Cron Jobs ───────────────────────────────────────────────────────────────

# Secret for authenticating cron job requests
# CRON_SECRET=

# ─── GitHub (optional) ───────────────────────────────────────────────────────

# GitHub PAT for higher API rate limits (marketplace indexing)
# GITHUB_TOKEN=
